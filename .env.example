# SYRUS environment variables
# Never commit real secrets.

# -------------------------------------------------------------------------
# MacOS desktop app
# -------------------------------------------------------------------------
# Set this in the desktop build/runtime when the backend is deployed.
# Example: https://your-syrus-api.up.railway.app
NEXUS_LUMA_API_BASE_URL=

# Local desktop development fallback only. In production, backend secrets
# should live on Railway, not inside the Mac app.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_PROVIDER=anthropic
VAPI_API_KEY=
NEXUS_LUMA_ENABLE_SIMULATED_USB_KEY=true

# -------------------------------------------------------------------------
# Railway backend
# -------------------------------------------------------------------------
PORT=8080
CORS_ORIGIN=*

# Google Sheets live lead data. Share the source sheet with the service
# account email from this JSON.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SPREADSHEET_ID=
GOOGLE_SHEET_NAME=Sheet1

# Gmail sending from the Railway backend.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# AI providers. Set one or both. AI_PROVIDER chooses the preferred one.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
AI_PROVIDER=anthropic

# SYRUS voice status / VAPI.
VAPI_API_KEY=
VAPI_PUBLIC_KEY=
